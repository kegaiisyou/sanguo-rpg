page {
  background: #0a0a0f;
  font-family: "STKaiti", "KaiTi", "STSong", "SimSun", "Microsoft YaHei", serif;
  color: #d4a853;
  overflow: hidden;
  height: 100vh;
}
/* 滚动条美化 */
::-webkit-scrollbar {
  width: 4px;
}
::-webkit-scrollbar-track {
  background: rgba(0,0,0,0.3);
  border-radius: 2px;
}
::-webkit-scrollbar-thumb {
  background: rgba(180,140,60,0.3);
  border-radius: 2px;
}
