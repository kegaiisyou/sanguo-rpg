{
  "pages": ["pages/game/game"],
  "subpackages": [
    {
      "root": "subpackages/asset",
      "pages": ["pages/placeholder/placeholder"],
      "independent": true
    }
  ],
  "preloadRule": {
    "pages/game/game": {
      "network": "all",
      "packages": ["subpackages/asset"]
    }
  },
  "window": {
    "navigationBarTitleText": "乱世烽火",
    "navigationBarBackgroundColor": "#0d1117",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#0a0a0f",
    "backgroundTextStyle": "dark",
    "disableScroll": true
  },
  "networkTimeout": {
    "request": 10000,
    "downloadFile": 10000
  },
  "debug": false
}
